{
  "name": "lindastay",
  "version": "1.0.0",
  "private": true,
  "description": "LindaStay production-ready SaaS vacation rental management PWA built with Framework7, Capacitor and Supabase.",
  "scripts": {
    "start": "python3 -m http.server 4173",
    "check": "node --check js/app.js",
    "cap:init": "npx cap init LindaStay com.lindastay.app --web-dir .",
    "cap:sync": "npx cap sync"
  },
  "dependencies": {
    "@capacitor/android": "latest",
    "@capacitor/cli": "latest",
    "@capacitor/core": "latest",
    "@capacitor/ios": "latest"
  },
  "devDependencies": {}
}
